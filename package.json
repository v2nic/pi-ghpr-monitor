{
  "name": "pi-ghpr-monitor",
  "version": "0.1.0",
  "description": "Pi extension that monitors GitHub PRs and injects status updates into the agent session",
  "keywords": [
    "pi-package"
  ],
  "main": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
